# MVP v0.1 does not require environment variables.
# These are optional defaults for Story 5 read-only data.

POLYMARKET_GAMMA_API_URL=https://gamma-api.polymarket.com
POLYMARKET_DATA_API_URL=https://data-api.polymarket.com
PREVIEW_MODE=true
COPY_SIZE=1
MAX_ORDER_SIZE_USD=2
PAPER_STARTING_BALANCE_USD=100
PAPER_TRADING_DAYS=14

# Future persistence
MONGODB_URI=

# Future alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

