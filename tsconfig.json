{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true
  },
  "include": [
    "next-env.d.ts",
    "pages/**/*.js",
    "pages/**/*.jsx",
    "pages/**/*.ts",
    "pages/**/*.tsx",
    "styles/**/*.css"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src",
    "api",
    "public",
    "docs"
  ]
}
